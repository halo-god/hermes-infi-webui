{
	auto_https off
}

hermes.infiled.com:80 {
	redir https://hermes.infiled.com{uri} permanent
}

hermes.infiled.com:443 {
	tls /home/hermes/hermes-infi-webui/CA/hermes.infiled.com.pem /home/hermes/hermes-infi-webui/CA/hermes.infiled.com.key

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	handle /api/* {
		reverse_proxy 127.0.0.1:8001
	}

	@websocket {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	reverse_proxy @websocket 127.0.0.1:8001

	handle {
		reverse_proxy 127.0.0.1:5173
	}
}
