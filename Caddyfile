{
	auto_https off
}

# HTTP to HTTPS redirect
hermes.infiled.com:80 {
	redir https://hermes.infiled.com{uri} permanent
}

hermes.infiled.com:443 {
	tls /home/hermes/hermes-infi-webui/CA/hermes.infiled.com.pem /home/hermes/hermes-infi-webui/CA/hermes.infiled.com.key

	# Security headers
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	# API backend
	handle /api/* {
		reverse_proxy 127.0.0.1:8001
	}

	# WebSocket support
	@websocket {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	reverse_proxy @websocket 127.0.0.1:8001

	# Web frontend (Vite preview)
	handle {
		reverse_proxy 127.0.0.1:5173
	}
}

# LAN IP – plain HTTP only (certificate mismatch fix)
192.168.30.31:80 {
	# API backend
	handle /api/* {
		reverse_proxy 127.0.0.1:8001
	}

	# WebSocket support
	@websocket {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	reverse_proxy @websocket 127.0.0.1:8001

	# Web frontend (Vite preview)
	handle {
		reverse_proxy 127.0.0.1:5173
	}
}

# VIP Kingdee Chromium cluster
vip.kingdee.infiled.com:3000 {
	tls /data/chromium/certs/vip.kingdee.infiled.com.pem /data/chromium/certs/vip.kingdee.infiled.com.key

	reverse_proxy 127.0.0.1:3001 127.0.0.1:3002 127.0.0.1:3003 127.0.0.1:3004 127.0.0.1:3005 127.0.0.1:3006 127.0.0.1:3007 127.0.0.1:3008 {
		lb_policy least_conn
		health_uri /
		health_interval 10s
		health_timeout 5s
	}

	header {
		Content-Security-Policy "upgrade-insecure-requests"
		Cache-Control "no-cache, no-store, must-revalidate"
	}
}
