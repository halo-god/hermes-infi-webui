# Copy to .env for local (non-docker) runs. In Docker, compose injects these.
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production-please-use-a-long-random-string

DATABASE_URL=postgresql+asyncpg://hermes:hermes@localhost:5432/hermes
REDIS_URL=redis://:your-redis-password@localhost:1979/0

CORS_ORIGINS=["http://localhost:5173"]

FIRST_ADMIN_EMAIL=admin@hermes.io
FIRST_ADMIN_PASSWORD=<set-a-strong-password-here>
FIRST_ADMIN_NAME=林知微
