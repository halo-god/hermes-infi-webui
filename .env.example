# Database
POSTGRES_USER=hermes
POSTGRES_PASSWORD=change-me
POSTGRES_DB=hermes

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ROOT_USER=hermes
MINIO_ROOT_PASSWORD=change-me
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=hermes

# API
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=change-me-to-a-secure-random-string-at-least-32-chars
DATABASE_URL=postgresql+asyncpg://hermes:change-me@postgres:5432/hermes
# Public origin of the app (scheme://host[:port]); required for OAuth postMessage scoping.
# Example: APP_BASE_URL=https://hermes.infiled.com
APP_BASE_URL=

# Agent Runner
ACP_LOG_LEVEL=info
